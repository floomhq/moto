# Claude Setup - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Gemini API (used by gemini-fetch.sh and gemini-audit hook)
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Server Infrastructure (if using multi-machine setup)
# ============================================================
# SSH alias for your dev server (used by enforce-server-routing hook)
CLAUDE_DEV_SERVER=your-dev-server
# SSH alias for your production server
CLAUDE_PROD_SERVER=your-prod-server

# ============================================================
# WhatsApp Gateway (OpenClaw)
# ============================================================
# Path to WhatsApp Desktop SQLite database
WHATSAPP_DB_PATH="$HOME/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/ChatStorage.sqlite"

# ============================================================
# Gmail IMAP (used by email-check skill)
# ============================================================
# Format: account_name:email:app_password:server
# Generate app passwords at https://myaccount.google.com/apppasswords
IMAP_ACCOUNT_1=personal:you@gmail.com:your_app_password:imap.gmail.com
# IMAP_ACCOUNT_2=work:you@company.com:your_app_password:imap.gmail.com

# ============================================================
# Cost Tracking
# ============================================================
# Directory where cost-tracker.sh writes costs.jsonl
CLAUDE_METRICS_DIR=$HOME/.claude/metrics

# ============================================================
# Package Manager Enforcement
# ============================================================
# Set to override auto-detection (npm, pnpm, yarn)
# CLAUDE_PACKAGE_MANAGER=pnpm

# ============================================================
# Compact Suggestion Threshold
# ============================================================
# Number of tool calls before suggesting /compact
COMPACT_THRESHOLD=50
