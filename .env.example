# Claude Setup - Environment Variables
# Copy this file to .env and fill in your values. NEVER commit .env.

# ============================================================
# Core Claude / hook configuration
# ============================================================

# Gemini API (used by gemini-fetch.sh and gemini-audit hook)
GEMINI_API_KEY=your_gemini_api_key_here

# SSH aliases for local hook routing
CLAUDE_DEV_SERVER=your-dev-server
CLAUDE_PROD_SERVER=your-prod-server

# WhatsApp Desktop SQLite database
WHATSAPP_DB_PATH="$HOME/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/ChatStorage.sqlite"

# Gmail IMAP accounts
# Format: account_name:email:app_password:server
IMAP_ACCOUNT_1=personal:you@gmail.com:your_app_password:imap.gmail.com
# IMAP_ACCOUNT_2=work:you@company.com:your_app_password:imap.gmail.com

# Cost tracking output
CLAUDE_METRICS_DIR=$HOME/.claude/metrics

# Optional package manager override
# CLAUDE_PACKAGE_MANAGER=pnpm

# Tool-call threshold before suggesting /compact
COMPACT_THRESHOLD=50

# ============================================================
# Integrated moto-compatible remote stack
# ============================================================

# Your Mac user. Used for SSHFS mounts on the server.
MAC_USER=yourname

# Public IP or hostname of your Linux box.
AX41_HOST=1.2.3.4
AX41_USER=root
AX41_SSH_KEY=~/.ssh/id_ed25519

# SSH alias used by the Mac-side moto CLI.
AX41_SSH_HOST=ax41

# Port on the server that forwards back to your Mac's sshd.
MAC_REVERSE_PORT=2222

# Remote runtime directory used by ./install.sh server-remote.
# The default /opt/moto is kept for compatibility with the bundled helpers.
# MOTO_REMOTE_DIR=/opt/moto

# Optional keys exported into remote tmux sessions.
# Prefer `ai-provider-key set <provider>` for sidecar keys. Do not store
# Groq/OpenRouter/NVIDIA sidecar keys here unless your own workflow requires
# environment-variable export.
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
DEEPINFRA_API_KEY=

# Cloudflare tunnel (optional)
CLOUDFLARE_TUNNEL_TOKEN=

# Residential proxy (optional)
PROXY_URL=
PROXY_APPLIES_TO=authenticated-chrome,runtime-api

# Cleanup thresholds
NODE_MODULES_GC_DAYS=14
NEXT_CPU_THRESHOLD=50
CHROME_MAX_AGE_HOURS=2
