[Unit]
Description=moto — CDP Docker bridge (socat :9222 host -> 172.17.0.1:9222)
After=authenticated-chrome.service docker.service

[Service]
Type=simple
ExecStart=/usr/bin/socat TCP-LISTEN:9222,bind=172.17.0.1,reuseaddr,fork TCP:127.0.0.1:9222
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
